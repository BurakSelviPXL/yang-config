<config>
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

    <hostname>YANG-AUTO</hostname>

    <interface>
      <GigabitEthernet>
        <name>1</name>
        <description>IFACE1</description>
        <ip>
          <address>
            <primary>
              <address>192.168.10.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
        <no_shutdown/>
      </GigabitEthernet>

      <GigabitEthernet>
        <name>2</name>
        <description>IFACE2</description>
        <ip>
          <address>
            <primary>
              <address>192.168.20.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
        <no_shutdown/>
      </GigabitEthernet>
    </interface>

    <router>
      <ospf>
        <process-id>1</process-id>
        <network>
          <ip>192.168.10.0</ip>
          <wildcard>0.0.0.255</wildcard>
          <area>0</area>
        </network>
      </ospf>
    </router>

  </native>
</config>
