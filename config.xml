<native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

  <hostname>Router-Automation</hostname>

  <interface>
    <GigabitEthernet>
      <name>1</name>
      <ip>
        <address>
          <primary>
            <address>192.168.1.10</address>
            <mask>255.255.255.0</mask>
          </primary>
        </address>
      </ip>
      <no_shutdown/>
    </GigabitEthernet>

    <GigabitEthernet>
      <name>2</name>
      <ip>
        <address>
          <primary>
            <address>192.168.2.1</address>
            <mask>255.255.255.0</mask>
          </primary>
        </address>
      </ip>
      <no_shutdown/>
    </GigabitEthernet>
  </interface>

  <router>
    <ospf>
      <id>1</id>
      <network>
        <ip>192.168.1.0</ip>
        <mask>0.0.0.255</mask>
        <area>0</area>
      </network>
      <network>
        <ip>192.168.2.0</ip>
        <mask>0.0.0.255</mask>
        <area>0</area>
      </network>
    </ospf>
  </router>

</native>
